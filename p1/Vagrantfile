# frozen_string_literal: true
require "yaml"

CFG = YAML.load_file(File.join(__dir__, "confs", "config.yaml"))

LOGIN    = CFG.fetch("login")
BOX      = CFG.fetch("box")
PROVIDER = CFG.fetch("provider")

Vagrant.configure("2") do |config|
  config.vm.box = BOX
  config.ssh.insert_key = true

  sf = CFG.fetch("synced_folder")

  # IMPORTANT for vagrant-libvirt 9p:
  # use "accessmode:" (NOT "9p__accessmode"), otherwise it falls back to "squash"
  config.vm.synced_folder ".", "/vagrant",
    type: sf.fetch("type"),
    accessmode: sf.fetch("accessmode"),
    msize: sf.fetch("msize"),
    owner: "1000",
    group: "1000"

  CFG.fetch("vms").each do |vm|
    script = vm.fetch("script")
    script_path = File.join(__dir__, script)
    raise "Script not found: #{script_path}" unless File.exist?(script_path)

    config.vm.define "#{LOGIN}#{vm.fetch("name")}" do |m|
      m.vm.hostname = "#{LOGIN}#{vm.fetch("hostname")}"
      m.vm.network "private_network", ip: vm.fetch("ip")

      m.vm.provider PROVIDER do |lv|
        lv.driver = "qemu"      # keep if KVM gives trouble; remove later if you want kvm accel
        lv.machine_type = "q35"
        lv.cpus   = CFG.dig("resources", "cpus") || 1
        lv.memory = CFG.dig("resources", "memory") || 1024
      end

      m.vm.provision "shell", inline: <<~SHELL
        set -e
        apt-get update -qq
        apt-get install -y curl net-tools
      SHELL

      m.vm.provision "shell", path: script, privileged: true
    end
  end
end
